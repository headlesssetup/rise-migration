    \"prompt\": \"3D computer animation, vibrant color palette, soft lighting, exaggerated facial features, rounded forms, cartoony proportions, high-detail texturing, depth-of-field effects, smooth shading, expressive character design, glossy surfaces, subtle environmental reflections, warm color tones, stylized realism, cinematic composition, playful aesthetic, hyper-detailed rendering, volumetric lighting, crisp focus on main subjects, harmonious color schemes.\",\n                \"version\": \"v1\",\n                \"previewUrl\": \"https://articulateusercontent.eu/assets/rise/assets/image-generation-style-thumbnails/3d-animation.png\"\n            },\n            {\n                \"id\": \"0028ec93-020e-4d74-a626-2e7c9a006a3c\",\n                \"isGlobal\": true,\n                \"name\": \"Watercolor\",\n                \"position\": 5000,\n                \"prompt\": \"Watercolor painting technique, loose brushstrokes, earth tones, fluid color blending, soft edges, transparent washes, atmospheric perspective, wet-on-wet effects, gestural details, light and shadow play, organic textures, color bleeding, spontaneous splatters, luminous quality, dynamic composition, impressionistic approach, suggestive forms, controlled color runs, layered pigments, expressive line work.\",\n                \"version\": \"v1\",\n                \"previewUrl\": \"https://articulateusercontent.eu/assets/rise/assets/image-generation-style-thumbnails/watercolor.png\"\n            },\n            {\n                \"id\": \"d1ed6e01-4727-475c-a630-c75d0c115320\",\n                \"isGlobal\": true,\n                \"name\": \"Painterly\",\n                \"position\": 6000,\n                \"prompt\": \"Watercolor painting technique, loose brushstrokes, soft color blending, transparent washes, wet-on-wet effects, gentle color gradients, impressionistic style, atmospheric perspective, layered pigments, subtle textures, delicate linework, vibrant yet harmonious palette, fluid edges, spontaneous splatters, light and shadow interplay, expressive detailing, gestural architectural rendering, traditional plain air painting aesthetic.\",\n                \"version\": \"v1\",\n                \"previewUrl\": \"https://articulateusercontent.eu/assets/rise/assets/image-generation-style-thumbnails/painterly.png\"\n            },\n            {\n                \"id\": \"efb0e74a-e07a-4cc0-8ce1-63bc80aea086\",\n                \"isGlobal\": true,\n                \"name\": \"Cinematic Photo\",\n                \"position\": 7000,\n                \"prompt\": \"Cinematic photo. 35mm photograph, film, bokeh, professional, 4k, highly detailed, realistic, film grain, background soft blur\",\n                \"version\": \"v1\",\n                \"previewUrl\": \"https://articulateusercontent.eu/assets/rise/assets/image-generation-style-thumbnails/cinematic-photo.png\"\n            },\n            {\n                \"id\": \"1a07ada3-215d-46da-885b-98ebd2e0715e\",\n                \"isGlobal\": true,\n                \"name\": \"Editorial\",\n                \"position\": 8000,\n                \"prompt\": \"Cartoon-style ink drawing, loose sketchy linework, minimal shading, black and white palette, quick gestural strokes, expressive character poses, simplified details, light wash effects, economical use of lines, comic strip aesthetic, hand-drawn quality, whimsical illustration style, selective detailing, contrast between line and wash, spontaneous feel, humorous tone, editorial cartoon approach, uncluttered composition, confident freehand technique\",\n                \"version\": \"v1\",\n                \"previewUrl\": \"https://articulateusercontent.eu/assets/rise/assets/image-generation-style-thumbnails/editorial.png\"\n            },\n            {\n                \"id\": \"9fc42418-13a9-477a-a984-5046494400c7\",\n                \"isGlobal\": true,\n                \"name\": \"Vector Illustration\",\n                \"position\": 9000,\n                \"prompt\": \"A polished corporate flat vector style with realistic proportions and professional presentation. The artwork features clean, geometric character designs with smooth facial features and carefully crafted hair textures that maintain vector simplicity while appearing more detailed than typical flat illustrations. Characters are rendered with friendly, approachable expressions and professional attire, . No line work. Minimal background elements.\",\n                \"version\": \"v1\",\n                \"previewUrl\": \"https://articulateusercontent.eu/assets/rise/assets/image-generation-style-thumbnails/vector-illustration.png\"\n            },\n            {\n                \"id\": \"aae7eb8c-3604-4dc7-a803-1667244727b4\",\n                \"isGlobal\": true,\n                \"name\": \"Vector Blues\",\n                \"position\": 10000,\n                \"prompt\": \"Minimalist vector illustration, flat color blocks, simplified geometric shapes, monochromatic blue color palette for the background elements, no outlines, absence of shading or gradients, stylized character design, two-dimensional perspective, uncluttered composition, subtle texturing, symmetrical elements, cartoon-like abstraction, negative space utilization, retro-inspired aesthetic, graphic design influence, crisp edges, simplified wave patterns, harmonious color balance, economical use of details.\",\n                \"version\": \"v1\",\n                \"previewUrl\": \"https://articulateusercontent.eu/assets/rise/assets/image-generation-style-thumbnails/vector-blues.png\"\n            },\n            {\n                \"id\": \"23f356dd-e4ea-4184-8104-1648f5835451\",\n                \"isGlobal\": true,\n                \"name\": \"Origami\",\n                \"position\": 11000,\n                \"prompt\": \"origami style, paper art, pleated paper, folded, origami art, pleats, cut and fold, centered composition\",\n                \"version\": \"v1\",\n                \"previewUrl\": \"https://articulateusercontent.eu/assets/rise/assets/image-generation-style-thumbnails/origami.png\"\n            },\n            {\n                \"id\": \"58bd6ed9-1bfa-418e-877c-4ec38e3fd861\",\n                \"isGlobal\": true,\n                \"name\": \"8-bit\",\n                \"position\": 12000,\n                \"prompt\": \"Pixel art style, limited color palette, retro video game aesthetic, 8-bit graphics, blocky textures, low-resolution details, pixelated outlines, layered background design, simple shading technique, nostalgic visual approach, flat color blocks, minimal anti-aliasing, sprite-like character design, side-scrolling perspective, chunky pixel clusters, dithering effects for color blending, depth created through color variation, classic gaming era visuals, simplified yet expressive scenery.\",\n                \"version\": \"v1\",\n                \"previewUrl\": \"https://articulateusercontent.eu/assets/rise/assets/image-generation-style-thumbnails/8-bit.png\"\n            }\n        ],\n        \"lessons\": [],\n        \"sources\": [],\n        \"updatedAt\": \"2026-06-23T09:24:02.559Z\",\n        \"audience\": null,\n        \"externalId\": \"YmFJemFVprCqfBzTY9y902fQibq723N-\",\n        \"externalType\": \"rise-course\",\n        \"imageStyleId\": \"ca4a66a6-55a4-4aca-af0d-7d6095825227\",\n        \"learningObjectives\": null,\n        \"step\": null,\n        \"title\": null,\n        \"tone\": null,\n        \"topics\": null,\n        \"formData\": null,\n        \"courseGenerationJob\": null,\n        \"magicImportJobs\": {\n            \"magicLessonImports\": [],\n            \"magicQuizImports\": []\n        }\n    }\n]"}
